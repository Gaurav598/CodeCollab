# MongoDB Atlas connection string (required)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?appName=<app>

# Redis (local or managed)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRATION=900
SERVICE_JWT_SECRET=replace-with-a-strong-service-secret
REFRESH_COOKIE_SECURE=false

# OAuth (leave as dummy to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI Gateway
GEMINI_API_KEY=

# Remote AWS Execution Engine (required for code execution feature)
EXECUTION_ENGINE_URL=https://your-aws-execution-engine.example.com
EXECUTION_ENGINE_API_KEY=

# Frontend public URLs
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_SYNC_WS_URL=ws://localhost:1234
NEXT_PUBLIC_STOMP_WS_URL=ws://localhost:8080/ws
